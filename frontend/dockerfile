# ============================================================
# frontend/Dockerfile — Development only
# ============================================================
# Used by docker-compose.dev.yml for hot reload dev server.
# Production build is handled by nginx/Dockerfile.
# ============================================================

FROM node:22-alpine
WORKDIR /app
COPY package*.json ./
RUN npm config set legacy-peer-deps true
RUN npm install
COPY . .
EXPOSE 3000
CMD ["npm", "start"]