# ============================================================
# Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Note: All vars must be prefixed with REACT_APP_ to be
# accessible in the React app at build time.
# ============================================================

# --- API Base URL ---
# Dev: proxied via setupProxy.js, so use relative or localhost
# Prod: set to the production backend URL
REACT_APP_API_BASE_URL=http://localhost:5000/api

# --- Socket.IO ---
# Derived from API base URL (strips /api suffix) in useChat.js
# No separate var needed unless you split API and WS hosts
