# ============================================================
# Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# --- Server ---
PORT=5000

# --- Database (overridden by docker-compose, set here for local dev without Docker) ---
MONGO_URI=mongodb://localhost:27017/labbooker?replicaSet=rs0
REDIS_URL=redis://localhost:6379

# --- JWT Secrets (generate unique random strings for each) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_EMAIL_SECRET=
JWT_RESET_SECRET=

# --- CORS & URLs ---
CORS_ORIGINS=http://localhost:3000,http://localhost:80
ORIGIN_ADDRESS=http://localhost:3000
BASE_BACKEND_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000
WS_URL=ws://localhost:5000
LOCAL_IP_URL=http://localhost:5000
WS_IP=ws://localhost:5000

# --- Email (SendGrid — see issue #3) ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SUPPORT_EMAIL=
# Legacy SMTP (to be replaced by SendGrid)
EMAIL=
PASSWORD=
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=

# --- Branding ---
COMPANY_NAME=Azrieli LabBooker
COMPANY_ADDRESS=Azrieli College, Jerusalem, Israel

# --- Cloudinary (to be removed — see issue #4) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_CLOUD_API_KEY=
CLOUDINARY_CLOUD_API_SECRET=

# --- Root User Seeding (see issue #6) ---
ROOT_EMAIL=
ROOT_PASSWORD=

# --- Approval Workflow (see issue #8) ---
PRIMARY_APPROVAL_MANAGER=
SECONDARY_APPROVAL_MANAGER=

# --- Timezone ---
TIMEZONE=Asia/Jerusalem
